{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://greenmetrics.it/schemas/events/report.generated.v1.json",
  "title": "ReportGeneratedEvent",
  "description": "CloudEvents 1.0 envelope: emitted by the worker when a report job succeeds.",
  "type": "object",
  "required": ["specversion", "id", "source", "type", "subject", "datacontenttype", "time", "data"],
  "properties": {
    "specversion": { "const": "1.0" },
    "id":          { "type": "string", "format": "uuid" },
    "source":      { "const": "greenmetrics-worker" },
    "type":        { "const": "it.greenmetrics.report.generated.v1" },
    "subject":     { "type": "string", "pattern": "^tenants/[0-9a-f-]{36}/reports/[0-9a-f-]{36}$" },
    "datacontenttype": { "const": "application/json" },
    "time":        { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["tenant_id", "report_id", "type", "period_from", "period_to", "data_freshness"],
      "properties": {
        "tenant_id":     { "type": "string", "format": "uuid" },
        "report_id":     { "type": "string", "format": "uuid" },
        "type":          { "type": "string", "enum": ["esrs_e1", "piano_5_0", "conto_termico", "tee", "audit_dlgs102", "monthly_consumption", "co2_footprint"] },
        "period_from":   { "type": "string", "format": "date-time" },
        "period_to":     { "type": "string", "format": "date-time" },
        "file_url":      { "type": "string", "format": "uri" },
        "data_freshness": { "type": "string", "examples": ["live", "cached_2h"] }
      }
    }
  }
}
