{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://greenmetrics.it/schemas/events/emission_factor.updated.v1.json",
  "title": "EmissionFactorUpdatedEvent",
  "description": "CloudEvents 1.0 envelope: emitted when ISPRA / Terna / AIB / GHG / EcoInvent factor refresh persists a new factor version.",
  "type": "object",
  "required": ["specversion", "id", "source", "type", "subject", "datacontenttype", "time", "data"],
  "properties": {
    "specversion": { "const": "1.0" },
    "id":          { "type": "string", "format": "uuid" },
    "source":      { "const": "greenmetrics-backend" },
    "type":        { "const": "it.greenmetrics.emission_factor.updated.v1" },
    "subject":     { "type": "string" },
    "datacontenttype": { "const": "application/json" },
    "time":        { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["code", "scope", "year", "value", "unit", "source", "valid_from"],
      "properties": {
        "code":        { "type": "string" },
        "description": { "type": "string" },
        "scope":       { "type": "integer", "enum": [1, 2, 3] },
        "year":        { "type": "integer" },
        "value":       { "type": "number" },
        "unit":        { "type": "string" },
        "source":      { "type": "string", "enum": ["ISPRA", "Terna", "AIB", "GHG_Protocol", "EcoInvent", "custom"] },
        "valid_from":  { "type": "string", "format": "date-time" },
        "valid_to":    { "type": "string", "format": "date-time" }
      }
    }
  }
}
