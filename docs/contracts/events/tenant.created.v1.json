{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://greenmetrics.it/schemas/events/tenant.created.v1.json",
  "title": "TenantCreatedEvent",
  "description": "CloudEvents 1.0 envelope: emitted when a new tenant is provisioned. Consumers: billing, provisioning automation, audit log.",
  "type": "object",
  "required": ["specversion", "id", "source", "type", "subject", "datacontenttype", "time", "data"],
  "properties": {
    "specversion": { "const": "1.0" },
    "id":          { "type": "string", "format": "uuid" },
    "source":      { "const": "greenmetrics-backend" },
    "type":        { "const": "it.greenmetrics.tenant.created.v1" },
    "subject":     { "type": "string", "pattern": "^tenants/[0-9a-f-]{36}$" },
    "datacontenttype": { "const": "application/json" },
    "time":        { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["tenant_id", "ragione_sociale", "partita_iva"],
      "properties": {
        "tenant_id":          { "type": "string", "format": "uuid" },
        "ragione_sociale":    { "type": "string", "minLength": 1 },
        "partita_iva":        { "type": "string", "pattern": "^[0-9]{11}$" },
        "codice_fiscale":     { "type": "string" },
        "sdi_code":           { "type": "string" },
        "pec":                { "type": "string", "format": "email" },
        "ateco":              { "type": "string" },
        "large_enterprise":   { "type": "boolean" },
        "csrd_in_scope":      { "type": "boolean" },
        "plan":               { "type": "string", "enum": ["small", "medium", "large", "stretch", "custom"] },
        "meter_quota":        { "type": "integer", "minimum": 1 }
      }
    }
  }
}
