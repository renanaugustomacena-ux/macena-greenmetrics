{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://greenmetrics.it/schemas/events/reading.ingested.v1.json",
  "title": "ReadingIngestedEvent",
  "description": "CloudEvents 1.0 envelope: emitted whenever a meter reading is durably persisted (HTTP ingest, Pulse webhook, or scheduled ingestor). Subject path: tenants/{tenant_id}/meters/{meter_id}.",
  "type": "object",
  "required": ["specversion", "id", "source", "type", "subject", "datacontenttype", "time", "data"],
  "properties": {
    "specversion": { "const": "1.0" },
    "id":          { "type": "string", "format": "uuid" },
    "source":      { "type": "string", "format": "uri-reference", "examples": ["greenmetrics-backend"] },
    "type":        { "const": "it.greenmetrics.reading.ingested.v1" },
    "subject":     { "type": "string", "pattern": "^tenants/[0-9a-f-]{36}/meters/[0-9a-f-]{36}$" },
    "datacontenttype": { "const": "application/json" },
    "time":        { "type": "string", "format": "date-time" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["tenant_id", "meter_id", "channel_id", "ts", "value", "unit", "source"],
      "properties": {
        "tenant_id":  { "type": "string", "format": "uuid" },
        "meter_id":   { "type": "string", "format": "uuid" },
        "channel_id": { "type": "string", "format": "uuid" },
        "ts":         { "type": "string", "format": "date-time" },
        "value":      { "type": "number" },
        "unit":       { "type": "string" },
        "quality_code": { "type": "integer", "minimum": 0, "maximum": 4 },
        "source":     { "type": "string", "enum": ["http_ingest", "modbus", "mbus", "sunspec", "pulse_webhook", "ocpp", "manual"] },
        "ingest_seq": { "type": "integer" }
      },
      "additionalProperties": false
    }
  }
}
