{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://greenmetrics.it/schemas/pack-manifest.schema.json",
  "title": "GreenMetrics Pack Manifest",
  "description": "Per-Pack manifest.yaml schema. Doctrine refs: Rule 70 (Pack manifests itself), Rule 75 (capabilities declared), Rule 83 (no recursive Pack discovery). Charter §4 (Pack Contract).",

  "type": "object",
  "additionalProperties": false,

  "required": [
    "id",
    "kind",
    "version",
    "min_core_version",
    "pack_contract_version",
    "author",
    "license_spdx",
    "capabilities"
  ],

  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{2,63}$",
      "description": "Pack identifier. Lowercase alphanumeric, underscores, hyphens. Length 3..64. Examples: modbus_tcp, ispra, esrs_e1, region-it."
    },
    "kind": {
      "type": "string",
      "enum": ["protocol", "factor", "report", "identity", "region"],
      "description": "Pack flavour per Charter §3.2."
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
      "description": "SemVer 2.0.0 version of this Pack."
    },
    "min_core_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
      "description": "Minimum Core version this Pack is compatible with. SemVer 2.0.0."
    },
    "pack_contract_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
      "description": "Pack-contract version this Pack implements. Per Rule 71."
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "description": "Pack author / maintainer (organisation or individual)."
    },
    "license_spdx": {
      "type": "string",
      "minLength": 1,
      "description": "SPDX license identifier (e.g. 'Proprietary', 'BUSL-1.1', 'AGPL-3.0', 'Apache-2.0')."
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-z][a-z0-9._-]*$"
      },
      "description": "Capabilities declared by this Pack. Matched against config/required-packs.yaml at boot per Rule 75."
    },
    "notes": {
      "type": "string",
      "description": "Optional human-readable notes on this Pack version."
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]{2,63}$"
      },
      "uniqueItems": true,
      "description": "Other Pack ids this Pack depends on. Loader resolves at boot."
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "Optional URL of Pack documentation."
    },
    "repository": {
      "type": "string",
      "format": "uri",
      "description": "Optional URL of Pack source repository."
    }
  }
}
