{
  "name": "greenmetrics-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "gen:branding": "node scripts/gen-branding.mjs",
    "dev": "npm run gen:branding && vite dev --port 3000 --host 0.0.0.0",
    "build": "npm run gen:branding && vite build",
    "preview": "vite preview",
    "check": "npm run gen:branding && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "npm run gen:branding && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint . --cache",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.7.3",
    "chart.js": "^4.4.3",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.18.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "postcss": "^8.5.13",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.6.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "esbuild": "^0.25.0"
  }
}
