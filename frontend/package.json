{
  "name": "greenmetrics-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "gen:branding": "node scripts/gen-branding.mjs",
    "dev": "npm run gen:branding && vite dev --port 3000 --host 0.0.0.0",
    "build": "npm run gen:branding && vite build",
    "preview": "vite preview",
    "check": "npm run gen:branding && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "npm run gen:branding && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint . --cache",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.7.3",
    "chart.js": "^4.4.3",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.6.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "@types/node": "^20.12.7",
    "@typescript-eslint/parser": "^8.18.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.6.0",
    "eslint-plugin-svelte": "^2.40.0",
    "postcss": "^8.4.39",
    "svelte": "^4.2.19",
    "svelte-check": "^3.8.6",
    "svelte-eslint-parser": "^0.41.0",
    "tailwindcss": "^3.4.10",
    "tslib": "^2.6.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vitest": "^2.0.5",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "esbuild": "^0.25.0"
  }
}
