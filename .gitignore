# ------------------------------------------------------------
# GreenMetrics .gitignore — Go + Node + Terraform + universal.
# ------------------------------------------------------------

# Env / secrets
.env
.env.local
*.pem
*.key
*.pfx
*.p12
credentials.json

# Go
backend/bin/
backend/*.out
backend/coverage.out
backend/coverage.html
*.exe
*.test
*.prof
vendor/

# Node / SvelteKit
node_modules/
.pnpm-store/
.yarn/
frontend/.svelte-kit/
frontend/build/
frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.vite/

# Tailwind / PostCSS
.postcss-cache/

# Terraform
terraform/.terraform/
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/*.tfvars
!terraform/*.tfvars.example
terraform/crash.log
terraform/crash.*.log
terraform/.terraform.lock.hcl

# Docker
.docker/
docker-compose.override.yml

# Grafana — keep provisioning but not runtime DB exports.
grafana/data/
grafana/logs/

# TimescaleDB dumps
*.sql.gz
*.dump
data/
pgdata/

# OS
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo

# IDE
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Build artefacts & logs
*.log
tmp/
out/
coverage/
dist/
build/

# Python helper scripts (if any)
__pycache__/
.venv/
